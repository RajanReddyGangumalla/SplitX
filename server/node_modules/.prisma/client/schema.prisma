generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SplitType {
  equal
  unequal
  percentage
  share
}

enum GroupMemberRole {
  admin
  member
}

enum AnomalyAction {
  IMPORTED
  SKIPPED
  FLAGGED
  RECLASSIFIED
  CONVERTED
}

model User {
  id        String   @id @default(uuid())
  name      String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  groupMemberships    GroupMember[]
  expensesPaid        Expense[]      @relation("ExpensePaidBy")
  splits              ExpenseSplit[]
  settlementsSent     Settlement[]   @relation("SettlementPayer")
  settlementsReceived Settlement[]   @relation("SettlementPayee")
}

model Group {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
}

model GroupMember {
  id       String          @id @default(uuid())
  userId   String
  groupId  String
  role     GroupMemberRole @default(member)
  joinedAt DateTime        @default(now())
  leftAt   DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
  @@index([leftAt])
}

model Expense {
  id               String    @id @default(uuid())
  groupId          String
  paidById         String
  description      String
  amount           Float
  originalAmount   Float?
  originalCurrency String?
  exchangeRate     Float?
  splitType        SplitType
  expenseDate      DateTime
  createdAt        DateTime  @default(now())
  importedRow      Int?

  group  Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy User           @relation("ExpensePaidBy", fields: [paidById], references: [id], onDelete: Restrict)
  splits ExpenseSplit[]

  @@index([groupId])
  @@index([paidById])
  @@index([importedRow])
}

model ExpenseSplit {
  id        String @id @default(uuid())
  expenseId String
  userId    String
  amount    Float

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([expenseId])
  @@index([userId])
}

model Settlement {
  id          String   @id @default(uuid())
  payerId     String
  payeeId     String
  groupId     String
  amount      Float
  settledAt   DateTime @default(now())
  importedRow Int?

  payer User  @relation("SettlementPayer", fields: [payerId], references: [id], onDelete: Restrict)
  payee User  @relation("SettlementPayee", fields: [payeeId], references: [id], onDelete: Restrict)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([payerId])
  @@index([payeeId])
  @@index([groupId])
}

model ImportLog {
  id         String   @id @default(uuid())
  importedAt DateTime @default(now())
  totalRows  Int
  imported   Int
  skipped    Int
  flagged    Int
  reportJson String

  anomalies ImportAnomaly[]

  @@index([importedAt])
}

model ImportAnomaly {
  id          String        @id @default(uuid())
  importLogId String
  rowNumber   Int
  field       String
  issue       String
  action      AnomalyAction
  originalVal String?
  resolvedVal String?

  importLog ImportLog @relation(fields: [importLogId], references: [id], onDelete: Cascade)

  @@index([importLogId])
  @@index([rowNumber])
}
